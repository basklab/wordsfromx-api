PORT=3001
API_PORT=
WEB_ORIGIN=http://127.0.0.1:5173

# The API reads these in order: POSTGRES_URL, POSTGRES_PRISMA_URL,
# POSTGRES_URL_NON_POOLING.
POSTGRES_URL=postgres://postgres:password@localhost:5432/postgres
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

SUPABASE_URL=http://local.supabase:8000
SUPABASE_JWT_SECRET=

# MyMemory translation provider. Free tier allows anonymous use, but an email
# increases the daily character quota.
MYMEMORY_EMAIL=
