PORT=3001
API_PORT=
WEB_ORIGIN=http://127.0.0.1:5173

# Neon connection. The API reads these in order: DATABASE_URL, POSTGRES_URL,
# POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING. Use the pooled URL.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require
# Unpooled URL for migrations (drizzle-kit). Recommended; falls back to DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth (Better Auth). Used to verify JWTs against the JWKS endpoint at
# ${NEON_AUTH_BASE_URL}/jwks. Find it in the Neon console > Auth > Configuration.
NEON_AUTH_BASE_URL=https://ep-example.region.aws.neon.tech/neondb/auth

# MyMemory translation provider. Free tier allows anonymous use, but an email
# increases the daily character quota.
MYMEMORY_EMAIL=
