{
  "name": "@wordsfromx/api-elysia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app.ts"
    },
    "./types": {
      "types": "./src/lib/types.ts",
      "default": "./src/lib/types.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@sinclair/typebox": "^0.34.49",
    "elysia": "^1.4.28",
    "fflate": "^0.8.2",
    "jose": "^6.2.3",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
